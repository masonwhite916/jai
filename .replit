modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
WHOP_COMPANY_ID = "biz_OZR80ib6g8K3LY"
WHOP_PLAN_ACCIDENTS = "plan_HtcnYTclKSeK2"
WHOP_PLAN_BASIC = "plan_gK0TcuyckVn6X"
WHOP_PLAN_RENTAL = "plan_ZdaSBn6h2C7tn"
TAQNYAT_LANG = "ar"
TAQNYAT_SENDER = "jaiksa"

[nix]
channel = "stable-25_05"
