{
  "expo": {
    "name": "JAI Roadside Assistance",
    "slug": "jai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jai-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D1B69"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jai.roadside"
    },
    "android": {
      "package": "com.jai.roadside"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JAI uses your location to send roadside help exactly where you are."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "JAI needs access to your photos so you can attach pictures of the vehicle issue."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
